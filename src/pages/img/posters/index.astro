---
import Layout from '~/layouts/Layout.astro';

const posterSections = [
  {
    title: 'Event posters',
    items: [
      { name: 'Pizza party', href: '/images/Event%20Posters/Pizza%20party.png' },
      { name: 'July 2025 ice cream social', href: '/images/Event%20Posters/July_2025_Ice_cream_social.png' },
      { name: 'Workers Day trifold front', href: '/images/Workers%20Day%20Trifold/Trifold%20side%201.png' },
      { name: 'Workers Day trifold back', href: '/images/Workers%20Day%20Trifold/Trifold%20side%202.png' }
    ]
  },
  {
    title: 'Join materials',
    items: [
      { name: 'Right to join a union notice', href: '/images/Join%20Notice/NOTICE%20-%20right%20to%20join%20a%20union%20blue.png' },
      { name: 'SPIT booklet poster', href: '/images/Union_Propaganda_Booklets_2.png' },
      { name: 'Reasonable accommodations poster', href: '/images/Unreasonable%20Accommodations/Reasonable_Accommodations0.5x.png' }
    ]
  }
];
---

<Layout
  title="Poster Archive"
  description="Printable posters, notices, and handout materials from the JPMC Workers Alliance."
>
  <main class="container mx-auto px-4 py-10">
    <section class="max-w-3xl">
      <h1 class="text-4xl font-bold text-jpmc-blue">Poster Archive</h1>
      <p class="mt-4 text-lg text-gray-700">
        This page collects the published poster and handout assets that are linked from the site.
        For booklet downloads, use the <a class="text-jpmc-red hover:underline" href="/booklet">booklet archive</a>.
      </p>
    </section>

    <section class="mt-10 grid gap-8 md:grid-cols-2">
      {posterSections.map((section) => (
        <article class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
          <h2 class="text-2xl font-semibold text-jpmc-blue">{section.title}</h2>
          <ul class="mt-4 space-y-3">
            {section.items.map((item) => (
              <li>
                <a class="text-jpmc-red hover:underline" href={item.href} target="_blank" rel="noreferrer">
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </section>
  </main>
</Layout>
